# ═══════════════════════════════════════════════════════════════════════════
# HireOps AI — Production environment
# Copy to .env.production on the VPS, fill in real values, never commit.
# ═══════════════════════════════════════════════════════════════════════════

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_DB=hireops
POSTGRES_USER=hireops
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Auth ──────────────────────────────────────────────────────────────────
# Used to sign JWT cookies. MUST be stable across restarts (or all sessions die).
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# Comma-separated emails that get is_superadmin=true on every startup.
# These users get the /admin panel and can impersonate any tenant.
SUPERADMIN_EMAILS=you@symprio.com

# ── Mistral AI ────────────────────────────────────────────────────────────
MISTRAL_API_KEY=mistral-api-key-here

# Agent IDs (your existing values)
RESUME_SCORER_AGENT_ID=ag_019ca3046554772bbbdf4d2b75bdd657
RESUME_SCORER_MOCK=false
EMAIL_CLASSIFIER_AGENT_ID=ag_019ca2d9a7a0773cb0104da31ed35b09
EMAIL_CLASSIFIER_MOCK=false
INTERVIEW_EVALUATOR_AGENT_ID=ag_019ca3de9e43774b868275a93a6f4d36
INTERVIEW_EVALUATOR_MOCK=false

# Per-plan daily LLM spend caps (USD). Override here if you want tighter limits.
FREE_DAILY_LLM_BUDGET=0.50
STARTER_DAILY_LLM_BUDGET=5.00
PRO_DAILY_LLM_BUDGET=50.00

# ── ElevenLabs ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_ROUND2_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=

# ── SMTP (Postfix on this VPS) ────────────────────────────────────────────
# Backend container reaches the host's Postfix via the Docker bridge gateway.
# Default Postfix on Ubuntu/Debian listens on 25 with no auth from localhost.
SMTP_HOST=host.docker.internal
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=false
SMTP_FROM=noreply@hireops.symprio.com

# ── Stripe (set after creating products in Stripe dashboard) ──────────────
STRIPE_SECRET_KEY=sk_live_or_sk_test
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STARTER_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_
STARTER_PRICE_USD=49
PRO_PRICE_USD=199

# ── Sentry ────────────────────────────────────────────────────────────────
# Free tier: https://sentry.io — create a project, copy the DSN here.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Gmail (only needed if you want auto-inbox-sync) ───────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_EMAIL=

# ── Branding ──────────────────────────────────────────────────────────────
COMPANY_NAME=HireOps AI
FRONTEND_URL=https://hireops.symprio.com
NEXT_PUBLIC_SITE_URL=https://hireops.symprio.com
